# PostgreSQL (required)
DATABASE_URL=postgresql://global_pulse:change_me@127.0.0.1:5432/global_pulse
# Or use discrete DB envs instead of DATABASE_URL:
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=global_pulse
# DB_USER=global_pulse
# DB_PASSWORD=change_me

# App
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_BASE_PATH=
NEXT_PUBLIC_BASE_PATH=
LOG_LEVEL=info

# Google
YOUTUBE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
ANALYZER_USE_GEMINI=true
ANALYZER_GEMINI_TIMEOUT_MS=25000
ANALYZER_LLM_CANONICAL_BATCH=12
ANALYZER_LLM_SUMMARY_TOP_N=5
GROQ_API_KEY=
GROQ_MODEL=moonshotai/kimi-k2-instruct-0905
ANALYZER_GROQ_TIMEOUT_MS=30000
ANALYZER_TFIDF_WINDOW_HOURS=168
ANALYZER_BURST_MIN_Z=2.0
ANALYZER_SIMILARITY_COSINE_AUTO=0.82
ANALYZER_SIMILARITY_COSINE_ASSIST=0.70
FEATURE_NEWS_PIPELINE=false
FEATURE_DUAL_MAP_UI=false

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_STOCK_REPORT_CHAT_ID=
TELEGRAM_PULSE_REPORT_CHAT_ID=

# Reddit (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Bluesky (optional)
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
# Default-ready regions: US/EU can use BLUESKY_DEFAULT_HANDLES when source-specific handles are empty.
# Other regions (KR/JP/TW/CN/ME/RU) stay effectively inactive until region handles are provided.
BLUESKY_MAX_HANDLES=12
BLUESKY_POSTS_PER_HANDLE=40
BLUESKY_SOURCE_POST_CAP=70
BLUESKY_DEFAULT_HANDLES=
BLUESKY_KR_HANDLES=
BLUESKY_JP_HANDLES=
BLUESKY_TW_HANDLES=
BLUESKY_CN_HANDLES=
BLUESKY_US_HANDLES=bsky.app
BLUESKY_EU_HANDLES=bsky.app
BLUESKY_ME_HANDLES=
BLUESKY_RU_HANDLES=

# Mastodon (optional)
MASTODON_ACCESS_TOKEN=
# Optional OAuth app credentials (needed only for app-level auth flows)
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=
MASTODON_MAX_INSTANCES=10
MASTODON_POSTS_PER_INSTANCE=70
MASTODON_SOURCE_POST_CAP=70
MASTODON_KR_INSTANCES=
MASTODON_JP_INSTANCES=
MASTODON_TW_INSTANCES=
MASTODON_CN_INSTANCES=
MASTODON_US_INSTANCES=https://mastodon.social
MASTODON_EU_INSTANCES=https://mastodon.social,https://mastodon.world
MASTODON_ME_INSTANCES=
MASTODON_RU_INSTANCES=

# Collector guardrails
COLLECTOR_SCRAPER_TIMEOUT_MS=90000
COLLECTOR_BROWSER_TIMEOUT_MS=150000
COLLECTOR_MAX_RSS_MB=1536
COLLECTOR_ENFORCE_SOURCE_INTERVAL=true
COLLECTOR_FORCE_RUN=false

NEXT_PUBLIC_FEATURE_DUAL_MAP_UI=false
