# PostgreSQL (required)
DATABASE_URL=postgresql://global_pulse:change_me@127.0.0.1:5432/global_pulse
# Or use discrete DB envs instead of DATABASE_URL:
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=global_pulse
# DB_USER=global_pulse
# DB_PASSWORD=change_me

# App
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_BASE_PATH=
NEXT_PUBLIC_BASE_PATH=
LOG_LEVEL=info

# Google
YOUTUBE_API_KEY=
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004
ANALYZER_LLM_CANONICAL_BATCH=12
ANALYZER_TFIDF_WINDOW_HOURS=168
ANALYZER_BURST_MIN_Z=2.0
ANALYZER_SIMILARITY_COSINE_AUTO=0.82
ANALYZER_SIMILARITY_COSINE_ASSIST=0.70
FEATURE_NEWS_PIPELINE=false
FEATURE_DUAL_MAP_UI=false

# Telegram
TELEGRAM_BOT_TOKEN=

# Reddit (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Collector guardrails
COLLECTOR_SCRAPER_TIMEOUT_MS=90000
COLLECTOR_BROWSER_TIMEOUT_MS=150000
COLLECTOR_MAX_RSS_MB=1536

NEXT_PUBLIC_FEATURE_DUAL_MAP_UI=false
